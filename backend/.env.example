# ============================================================
# ChainSentinel — Environment Configuration
# ============================================================
# Copy this file to .env and fill in the values

# ---- Application ----
APP_NAME=ChainSentinel
APP_VERSION=0.1.0
DEBUG=true
SECRET_KEY=your-super-secret-key-change-in-production
ALLOWED_HOSTS=localhost,127.0.0.1

# ---- Database (PostgreSQL) ----
DATABASE_URL=postgresql+asyncpg://chainsentinel:chainsentinel@localhost:5432/chainsentinel
POSTGRES_USER=chainsentinel
POSTGRES_PASSWORD=chainsentinel
POSTGRES_DB=chainsentinel

# ---- Redis ----
REDIS_URL=redis://localhost:6379/0

# ---- Neo4j ----
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=chainsentinel

# ---- Celery ----
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ---- JWT ----
JWT_SECRET_KEY=your-jwt-secret-key
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ---- Blockchain Provider ----
PROVIDER_MODE=demo
# For real providers (optional):
# ETHERSCAN_API_KEY=your-etherscan-api-key
# ALCHEMY_API_KEY=your-alchemy-api-key
# BLOCKSTREAM_API_URL=https://blockstream.info/api

# ---- LLM Configuration ----
LLM_PROVIDER=openai
# OpenAI
OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-4
# Ollama (local)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# ---- Rate Limiting ----
RATE_LIMIT_PER_MINUTE=60

# ---- Logging ----
LOG_LEVEL=INFO
